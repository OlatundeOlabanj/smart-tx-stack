{
  "compilerOptions": {
    "target":            "ES2020",
    "module":            "commonjs",
    "lib":               ["ES2020"],
    "strict":            true,
    "esModuleInterop":   true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir":            "dist",
    "rootDir":           "src",
    "skipLibCheck":      true,
    "declaration":       true,
    "declarationMap":    true,
    "sourceMap":         true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
